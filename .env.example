# Neural Rank — environment variable reference
# Copy to .env for local development. Never commit .env.
# Production values live in the Render dashboard only (render.yaml uses sync: false).

# Node environment — set to 'production' on Render; leave as 'development' for local dev
NODE_ENV=development

# Supabase project credentials
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>

# SERP provider — choose one: serpapi | dataforseo
SERP_PROVIDER=serpapi
SERP_API_KEY=<your-serp-api-key>

# Headless renderer for JS-rendered DOM analysis (optional)
RENDERER_ENDPOINT=https://<your-renderer-service-url>

# Database connection string (required for persistent execution data)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Server port — Render sets this automatically; override only for local dev
PORT=10000

# CORS allowed origin — '*' allows all origins (default for dev); set to your Flutter web or dashboard domain in production
ALLOWED_ORIGIN=*

# Number of trusted proxy hops in front of the server — Render uses 1
TRUSTED_PROXY_COUNT=1

# Neural Rank — environment variable reference
# Copy to .env for local development. Never commit .env.
# Production values live in the Render dashboard only (render.yaml uses sync: false).

# Node environment — set to 'production' on Render; leave as 'development' for local dev
NODE_ENV=development

# Supabase project credentials
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>

# SERP provider — choose one: serpapi | dataforseo
SERP_PROVIDER=serpapi
SERP_API_KEY=<your-serp-api-key>

# Headless renderer for JS-rendered DOM analysis (optional)
RENDERER_ENDPOINT=https://<your-renderer-service-url>

# Database connection string (required for persistent execution data)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Server port — Render sets this automatically; override only for local dev
PORT=10000

# CORS allowed origin — '*' allows all origins (default for dev); set to your Flutter web or dashboard domain in production
ALLOWED_ORIGIN=*

# Number of trusted proxy hops in front of the server — Render uses 1
TRUSTED_PROXY_COUNT=1

# Per-module execution timeout in milliseconds — default 10s; increase for slow adapters
MODULE_TIMEOUT_MS=10000

# Sentry DSN for error tracking (optional — leave blank to disable)
SENTRY_DSN=

# ── Integration adapter credentials ──────────────────────────────────────────

# Google Search Console — used by: rank_tracking, topical_authority modules
# Obtain an OAuth 2.0 access token from Google Cloud Console (Search Console scope)
GSC_ACCESS_TOKEN=<oauth2-access-token>
GSC_SITE_URL=https://your-site.com/

# Google Analytics 4 — used by: analytics_integration module
GA4_ACCESS_TOKEN=<oauth2-access-token>
GA4_PROPERTY_ID=<ga4-property-id>

# PageSpeed Insights — used by: technical_seo_audit module
# Free Google Cloud API key with PageSpeed Insights API enabled
PAGESPEED_API_KEY=<google-cloud-api-key>

# Backlink provider — used by: backlink_intelligence module
# Choose one provider: ahrefs | moz | semrush
BACKLINK_PROVIDER=ahrefs
BACKLINK_API_KEY=<your-backlink-api-key>
BACKLINK_TARGET=<default-target-domain>
